/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for all data, with an exception for admin users.
 *
 * Data Structure:
 * - /users/{userId}: Stores core user account information. Only the authenticated user can read/write their own document. Admins can list and read all user documents.
 * - /users/{userId}/profiles/{profileId}: Stores additional user profile information. Only the authenticated user can read/write their own profile.
 *
 * Key Security Decisions:
 * - Users can only access their own data unless they are an admin.
 * - The `isAdmin` flag on a user document is protected; it cannot be set by a user on their own document.
 *
 * Denormalization for Authorization:
 * - The `userId` is embedded in the path for both the User and UserProfile collections, enabling simple `isOwner(userId)` checks.
 * - Admin access relies on checking the `isAdmin` flag on the requester's own user document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user account information.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // Allow a user to create their own document. The `isAdmin` field cannot be set to true on creation.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId && request.resource.data.isAdmin == false;
      
      // Allow a user to get their own document. Allow an admin to get any user document.
      allow get: if isSignedIn() && (isOwner(userId) || isRequesterAdmin());
      
      // Allow a user to update their own document, but not to make themselves an admin.
      // An admin can update any user document.
      allow update: if isSignedIn() && (
        (isOwner(userId) && isNotElevatingToAdmin()) || isRequesterAdmin()
      ) && request.resource.data.id == resource.data.id;

      // Allow a user to delete their own document.
      allow delete: if isSignedIn() && isOwner(userId);
      
      // Allow admins to list all users.
      allow list: if isSignedIn() && isRequesterAdmin();
    }

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}/profiles/{profileId}
     */
    match /users/{userId}/profiles/{profileId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == profileId;
      allow get: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.id == profileId;
      allow delete: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isRequesterAdmin() {
      // Check the `isAdmin` flag on the *requester's* user document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isNotElevatingToAdmin() {
      // Prevent a user from setting isAdmin to true on their own document.
      // It allows an admin to grant admin rights to another user because this is checked along with isOwner.
      return !('isAdmin' in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin || request.resource.data.isAdmin == false;
    }
  }
}
